{
	"name": "email-inbound-parse-webhook",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@10.19.0",
	"scripts": {
		"deploy:worker": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest run",
		"test:watch": "vitest",
		"baseline:compare": "tsx scripts/baseline-compare.ts",
